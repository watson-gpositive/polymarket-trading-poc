# Runtime
NODE_ENV=development
PAPER_MODE=true
LOOP_INTERVAL_SEC=60

# Risk defaults (safe)
MAX_RISK_PER_MARKET_PCT=2
MAX_CONCURRENT_POSITIONS=8
DAILY_STOP_LOSS_PCT=5
MIN_EDGE_CENTS=3
SLIPPAGE_BUFFER_CENTS=1
ARB_TRIGGER_MAX_TOTAL_CENTS=98
MIN_DEPTH_SHARES_PER_LEG=50

# Optional filtering/telemetry
MARKET_SCOPE=all
FOCUS_CATEGORIES=politics,crypto

# Polymarket endpoints (public data)
POLY_GAMMA_BASE=https://gamma-api.polymarket.com
POLY_CLOB_BASE=https://clob.polymarket.com

# Wallet analysis target (from thread)
REFERENCE_WALLET=0xD9E0AACa471f48F91A26E8669A805f2
