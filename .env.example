# Runtime
NODE_ENV=development
PAPER_MODE=true
LOOP_INTERVAL_SEC=60

# Risk defaults (safe)
MAX_RISK_PER_MARKET_PCT=2
MAX_CONCURRENT_POSITIONS=8
DAILY_STOP_LOSS_PCT=5
MIN_EDGE_CENTS=3
SLIPPAGE_BUFFER_CENTS=1
ARB_TRIGGER_MAX_TOTAL_CENTS=98
MIN_DEPTH_SHARES_PER_LEG=50
TARGET_SHARES_PER_TRADE=50
QUEUE_FILL_FACTOR=0.9
INV_ENTRY_MIN_PRICE_CENTS=10
INV_ENTRY_MAX_PRICE_CENTS=55
INV_HEDGE_MAX_TOTAL_CENTS=100
V2_MODE=mimic_732f1
V2_MAX_OPEN_POSITIONS=40
V2_REBALANCE_STEP_SHARES=25
V2_HEDGE_URGENCY_TICKS=3
D_ENABLED=false
D_MAX_OPEN_POSITIONS=20
D_MAX_NEW_ENTRIES_PER_TICK=2
D_MIN_ENTRY_PRICE_CENTS=20
D_MAX_ENTRY_PRICE_CENTS=50
D_MAX_EXPOSURE_TICKS=12
C_MAX_OPEN_POSITIONS=5
C_TARGET_SHARES_PER_TRADE=5
C_HEDGE_MAX_TOTAL_CENTS=102
C_HEDGE_URGENCY_TICKS=4
C_MIN_SPREAD_CENTS=3
B_HEDGE_URGENCY_TICKS=6
B_MAX_ENTRY_TOTAL_CENTS=101
B_MIN_NET_EDGE_CENTS=2
D_MIN_NET_EDGE_CENTS=2
A_OBSERVE_MAX_TOTAL_CENTS=100
A_TRADE_MAX_TOTAL_CENTS=99
A_MICRO_SHARES_PER_TRADE=5

# Optional filtering/telemetry
MARKET_SCOPE=all
FOCUS_CATEGORIES=politics,crypto

# Polymarket endpoints (public data)
POLY_GAMMA_BASE=https://gamma-api.polymarket.com
POLY_CLOB_BASE=https://clob.polymarket.com

# Wallet analysis target (from thread)
REFERENCE_WALLET=0xD9E0AACa471f48F91A26E8669A805f2

# Log management
LOG_MAX_BYTES=2000000
LOG_KEEP_FILES=5
